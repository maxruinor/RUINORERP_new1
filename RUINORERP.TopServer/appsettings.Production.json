{
  "ServerOptions": {
    "Name": "RUINORERP.ManagementServer",
    "Ip": "0.0.0.0",
    "Port": 8090,
    "MaxConnectionCount": 1000
  },

  "DatabaseConfiguration": {
    "ConnectionString": "Server=production-server;Database=RUINORERP_ManagementServer;User Id=erp_user;Password=production_password;TrustServerCertificate=True;",
    "UseDebug": false
  },

  "RedisConfiguration": {
    "Server": "redis-server:6379",
    "Password": "redis_password",
    "DefaultDatabase": 0
  },

  "Logging": {
    "LogLevel": {
      "System": "Warning",
      "Default": "Warning",
      "Microsoft": "Warning",
      "RUINORERP.TopServer": "Information"
    }
  }
}
