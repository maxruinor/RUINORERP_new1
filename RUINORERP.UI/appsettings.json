{
  "Logging": {
    "Debug": {
      "IncludeScopes": false,
      "LogLevel": {
        "Default": "Warning",
        "RUINORERP": "Warning",
        "RUINORERP.UI": "Warning",
        "RUINORERP.Business": "Warning"
      }
    },
    "Console": {
      "IncludeScopes": false,
      "LogLevel": {
        "Default": "Warning",
        "RUINORERP": "Warning",
        "RUINORERP.UI": "Warning",
        "RUINORERP.Business": "Warning"
      }
    },
    "Log4Net": {
      "Name": "ApeVoloLog",
      "InternalDebug": false
    }
  },
  "Middleware": {
    "RecordAllLogs": {
      "Enabled": false
    },
    "QuartzNetJob": {
      "Enabled": true
    },
    "IpLimit": {
      "Enabled": true
    },
    "MiniProfiler": {
      "Enabled": true
    },
    "RedisMq": {
      "Enabled": true
    }
  },
  "AllowedHosts": "*",

  "AuditLog": {
    "BatchSize": 3,
    "FlushInterval": 3000,
    "EnableAudit": true
  },

  // SqlSugar 配置
